# Параметры локальной PostgreSQL для IT-Pearls Recruiting.
# Скопируйте в .env.local и при необходимости измените значения.
# Используется docker-compose.yml; приложение CUBA читает настройки из context.xml.

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=itpearls
POSTGRES_USER=cuba
POSTGRES_PASSWORD=cuba

# JDBC URL (для справки; в проекте задаётся в modules/core/web/META-INF/context.xml)
# jdbc:postgresql://localhost:5432/itpearls
