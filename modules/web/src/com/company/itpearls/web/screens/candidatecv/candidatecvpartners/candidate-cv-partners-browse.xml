<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<window xmlns="http://schemas.haulmont.com/cuba/screen/window.xsd"
        xmlns:ext="http://schemas.haulmont.com/cuba/window-ext.xsd"
        extends="com/company/itpearls/web/screens/candidatecv/candidate-cv-browse.xml"
        messagesPack="com.company.itpearls.web.screens.candidatecv.candidatecvpartners">
    <data>
        <collection id="candidateCVsDc"
                    class="com.company.itpearls.entity.CandidateCVPartners">
            <view extends="candidateCVPartners-view">
                <property name="candidate" view="_local"/>
            </view>
            <loader id="candidateCVsDl">
                <query>
                    <![CDATA[select e from itpearls_CandidateCVPartners e order by e.candidate.fullName,  e.datePost desc]]>
                </query>
            </loader>
        </collection>
    </data>
    <layout/>
</window>
