<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<window xmlns="http://schemas.haulmont.com/cuba/screen/window.xsd"
        xmlns:ext="http://schemas.haulmont.com/cuba/window-ext.xsd"
        xmlns:c="http://schemas.haulmont.com/cuba/screen/jpql_condition.xsd"
        extends="com/company/itpearls/web/screens/candidatecv/candidate-cv-browse.xml"
        messagesPack="com.company.itpearls.web.screens.candidatecv.candidatecvpartners">
    <data>
        <collection id="candidateCVsPartnersDc"
                    class="com.company.itpearls.entity.CandidateCVPartners">
            <view extends="candidateCVPartners-view">
                <property name="partners" view="partners-view"/>
                <property name="candidate" view="_local">
                    <property name="fullName"/>
                    <property name="personPosition" view="_local"/>
                    <property name="fileImageFace" view="_local"/>
                </property>
                <property name="toVacancy" view="openPosition-view">
                    <property name="positionType" view="_local"/>
                    <property name="projectName" view="_local">
                        <property name="projectLogo" view="_local"/>
                    </property>
                </property>
                <property name="resumePosition" view="_local">
                    <property name="logo" view="_local"/>
                </property>
                <property name="owner" view="_local">
                    <property name="fileImageFace" view="_local"/>
                </property>
            </view>
            <loader id="candidateCVsPartnersDl"
                    cacheable="true">
                <query>
                    <![CDATA[select e
                    from itpearls_CandidateCVPartners e
                    order by e.candidate.fullName]]>
                    <condition>
                        <and>
                            <c:jpql>
                                <c:where>
                                    e.partners = :partners
                                </c:where>
                            </c:jpql>
                            <c:jpql>
                                <c:where>
                                    e.createdBy like :userName
                                </c:where>
                            </c:jpql>
                        </and>
                    </condition>
                </query>
            </loader>
        </collection>
    </data>
    <layout>
        <dataGrid id="candidateCVsTable"
                  dataContainer="candidateCVsPartnersDc"/>
    </layout>
</window>
