        <collection id="openPosDc"
                    class="com.company.itpearls.entity.OpenPosition">
            <view extends="_local">
                <property name="grade"
                          view="_minimal"/>
                <property name="positionType"
                          view="_local"/>
                <property name="owner"
                          view="_local"/>
                <property name="projectName"
                          view="_local">
                    <property name="projectLogo"
                              view="_local"/>
                    <property name="projectDepartment"
                              view="_local">
                        <property name="companyName"
                                  view="_local"/>
                    </property>
                </property>
            </view>
            <loader id="openPosDl"
                    cacheable="true">
                <query>
                    <![CDATA[select e from itpearls_OpenPosition e
                                order by e.openClose, e.vacansyName]]>
                    <condition>
                        <and>
                            <c:jpql>
                                <c:where>
                                    e in (select b.openPosition from itpearls_PartnersSubscribeOpenPosition b
                                    where b.active = true
                                    and (b.endDate >= :currDate or b.endDate is null)
                                    and b.partner in
                                    (select c.partners from itpearls_PartnersPerson c
                                    where c.partnerPersonLogin like :userlogin))
                                </c:where>
                            </c:jpql>
                            <c:jpql>
                                <c:where>
                                    e.companyDepartament = :departament
                                </c:where>
                            </c:jpql>
                            <c:jpql>
                                <c:where>
                                    e in (select k.openPosition from itpearls_RecrutiesTasks k
                                    where k.reacrutier = :subscriber
                                    and k.closed = false
                                    and current_date between k.startDate and k.endDate)
                                </c:where>
                            </c:jpql>
                        </and>
                    </condition>
                </query>
            </loader>
        </collection>
        <collection id="partnersDc"
                    class="com.company.itpearls.entity.Partners"
                    view="partners-view">
            <loader id="partnersDl"
                    cacheable="true">
                <query>
                    <![CDATA[select e from itpearls_Partners e]]>
                </query>
            </loader>
        </collection>
        <instance id="candidateCVDc"
                  class="com.company.itpearls.entity.CandidateCVPartners">
            <view extends="candidateCVPartners-view"/>
        </instance>

    </data>
    <layout>
        <lookupPickerField id="partnersLookupPickerField"
                           ext:index="0"
                           dataContainer="candidateCVDc"
                           property="partners"
                           nullOptionVisible="false"
                           required="true"
                           editable="false"
                           caption="msg://msgPartners"
                           optionsContainer="partnersDc">
            <actions>
                <action id="lookup"
                        type="picker_lookup"/>
                <action id="open"
                        type="picker_open"
                        icon="EDIT_ACTION"/>
            </actions>
        </lookupPickerField>
        <tabSheet id="tabSheet">
            <tab id="tabCandidate">
                <scrollBox id="candidateScrolBox">
                    <hbox id="candidateVbox">
                        <vbox id="groupBox">
                            <vbox id="candidateFieldVBox">
                                <suggestionPickerField id="candidateField">
                                    <actions>
                                        <action id="lookup" type="picker_lookup" visible="false"/>
                                        <action id="open" type="picker_open" visible="false"/>
                                    </actions>
                                </suggestionPickerField>
                                <vbox id="candidateCVFieldOpenPositionVBox">
                                    <lookupPickerField id="candidateCVFieldOpenPosition"
                                                       dataContainer="candidateCVDc"
                                                       property="toVacancy"
                                                       optionsContainer="openPosDc">
                                        <actions>
                                            <action id="lookup"
                                                    type="picker_lookup" visible="false"/>
                                            <action id="open"
                                                    type="picker_open" visible="false"/>
                                        </actions>
                                    </lookupPickerField>
                                </vbox>
                            </vbox>
                        </vbox>
                    </hbox>
                </scrollBox>
            </tab>
        </tabSheet>
    </layout>
</window>
