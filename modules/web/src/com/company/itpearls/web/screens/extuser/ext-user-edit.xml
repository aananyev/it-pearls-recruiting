<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<window xmlns="http://schemas.haulmont.com/cuba/window.xsd"
        class="com.haulmont.cuba.gui.app.security.user.edit.UserEditor"
        caption="msg://extUserEdit.caption"
        messagesPack="com.company.itpearls.web.screens.extuser"
        datasource="userDs"
        focusComponent="settingsTabSheet">
    <companions>
        <web class="com.haulmont.cuba.web.app.ui.security.user.UserEditorCompanion"/>
    </companions>
    <dsContext>
        <datasource id="userDs"
                    class="com.haulmont.cuba.security.entity.User"
                    view="extUser-view">
            <groupDatasource id="rolesDs" property="userRoles"/>
            <collectionDatasource id="substitutionsDs" property="substitutions"/>
        </datasource>
        <collectionDatasource id="userAiConfigsDs"
                            class="com.company.itpearls.entity.UserAiConfiguration"
                            view="userAiConfiguration-view">
            <query>
                <![CDATA[select e from itpearls_UserAiConfiguration e where e.user = :ds$userDs]]>
            </query>
        </collectionDatasource>
    </dsContext>
    <dialogMode height="850"
                width="theme://cuba.gui.dialogSize.width.xlarge"
                resizable="true"/>
    <layout expand="mainSplit" spacing="true">
        <split id="mainSplit" orientation="horizontal" pos="25" width="100%" height="100%" expand="settingsTabSheet">
            <vbox id="profilePanel"
                  width="100%"
                  height="100%"
                  spacing="true"
                  margin="true"
                  stylename="well"
                  align="TOP_CENTER">
                <label value="msg://msgProfile" stylename="h2" align="TOP_CENTER" width="100%"/>
                <vbox id="dropZone"
                      spacing="true"
                      width="100%"
                      align="TOP_CENTER"
                      stylename="dropzone-container">
                    <fallbackImage id="userPic"
                                  width="180px"
                                  height="180px"
                                  align="MIDDLE_CENTER"
                                  scaleMode="SCALE_DOWN"
                                  datasource="userDs"
                                  property="officialPhoto"/>
                    <upload id="officialPhotoUpload"
                            fileStoragePutMode="IMMEDIATE"
                            datasource="userDs"
                            align="BOTTOM_CENTER"
                            showFileName="false"
                            dropZone="dropZone"
                            showClearButton="true"
                            property="officialPhoto"/>
                </vbox>
                <vbox id="profileLabelsVBox"
                      spacing="true"
                      align="TOP_CENTER"
                      width="100%">
                    <label id="fioLabel" stylename="h1" align="MIDDLE_CENTER" width="100%"/>
                    <label id="loginLabel" stylename="large" align="MIDDLE_CENTER" width="100%"/>
                    <label id="statusLabel" align="MIDDLE_CENTER" width="100%"/>
                </vbox>
            </vbox>
            <tabSheet id="settingsTabSheet" width="100%" height="100%" stylename="framed">
                <tab id="generalSettingsTab"
                     caption="msg://msgGeneralSettings"
                     margin="true"
                     spacing="true"
                     expand="rolesSubstSplit">
                    <scrollBox id="generalScrollBox" width="100%" spacing="true">
                        <vbox id="passwordBox"
                              spacing="true"
                              visible="false"
                              width="100%"
                              margin="true,true,true,true"
                              stylename="card">
                            <fieldGroup id="fieldGroupLeft" datasource="userDs" width="100%">
                                <column width="100%">
                                    <field id="passw" custom="true" caption="msg://password"/>
                                    <field id="confirmPassw" custom="true" caption="msg://confirmPassword"/>
                                </column>
                            </fieldGroup>
                        </vbox>
                        <hbox spacing="true" width="100%">
                            <groupBox flat="true" spacing="true" width="100%" flex="1">
                                <label value="msg://msgContacts" stylename="h3"/>
                                <fieldGroup id="contactsFieldGroup" datasource="userDs" width="100%">
                                    <column width="100%">
                                        <field id="login" required="true" requiredMessage="msg://loginMsg"/>
                                        <field id="firstName"/>
                                        <field id="middleName"/>
                                        <field id="lastName"/>
                                        <field id="name"/>
                                        <field id="email">
                                            <validator class="com.haulmont.cuba.gui.components.validators.EmailValidator"
                                                       message="msg://email.alert"/>
                                        </field>
                                    </column>
                                </fieldGroup>
                            </groupBox>
                            <groupBox flat="true" spacing="true" width="100%" flex="1">
                                <label value="msg://msgRegional" stylename="h3"/>
                                <fieldGroup id="fieldGroupRight" datasource="userDs" width="100%">
                                    <column width="100%">
                                        <field id="language" custom="true"/>
                                        <field id="timeZone" custom="true"/>
                                        <field id="group" custom="true"/>
                                        <field id="position"/>
                                        <field id="ipMask"/>
                                        <field id="active"/>
                                        <field id="statistics"/>
                                        <field id="dashboards"/>
                                    </column>
                                </fieldGroup>
                            </groupBox>
                        </hbox>
                    </scrollBox>
                    <split id="rolesSubstSplit"
                           orientation="horizontal"
                           pos="50"
                           width="100%"
                           height="100%"
                           expand="substPanel"
                           margin="true,false,false,false">
                        <vbox id="rolesPanel" expand="rolesTable" spacing="true" margin="false,true,false,false"
                              height="100%" width="100%">
                            <label value="msg://roles" stylename="h3"/>
                            <buttonsPanel>
                                <button id="rolesTableAddBtn"/>
                                <button id="rolesTableEditBtn" action="rolesTable.edit"/>
                                <button id="rolesTableRemoveBtn" action="rolesTable.remove"/>
                            </buttonsPanel>
                            <groupTable id="rolesTable" editable="false" multiselect="true" width="100%"
                                        height="100%" fixedGrouping="true">
                                <actions>
                                    <action id="edit"/>
                                    <action id="remove"/>
                                </actions>
                                <columns>
                                    <column id="role.name" caption="msg://roleName"/>
                                    <column id="role.locName" caption="msg://localizedRoleName"/>
                                    <column id="role.locSecurityScope"/>
                                </columns>
                                <rows datasource="rolesDs"/>
                            </groupTable>
                        </vbox>
                        <vbox id="substPanel" expand="substTable" spacing="true" margin="false,false,false,true"
                              height="100%" width="100%">
                            <label value="msg://substUsers" stylename="h3"/>
                            <buttonsPanel>
                                <button id="substTableAddBtn" action="substTable.add"/>
                                <button id="substTableEditBtn" action="substTable.edit"/>
                                <button id="substTableRemoveBtn" action="substTable.remove"/>
                            </buttonsPanel>
                            <table id="substTable" editable="false" multiselect="true" width="100%"
                                   height="100%">
                                <actions>
                                    <action id="add"/>
                                    <action id="edit"/>
                                    <action id="remove"/>
                                </actions>
                                <columns>
                                    <column id="substitutedUser.login" caption="msg://login"/>
                                    <column id="substitutedUser.name" caption="msg://name"/>
                                    <column id="startDate" caption="msg://startDate">
                                        <formatter class="com.haulmont.cuba.gui.components.formatters.DateFormatter"
                                                   type="DATE"/>
                                    </column>
                                    <column id="endDate" caption="msg://endDate">
                                        <formatter class="com.haulmont.cuba.gui.components.formatters.DateFormatter"
                                                   type="DATE"/>
                                    </column>
                                </columns>
                                <rows datasource="substitutionsDs"/>
                            </table>
                        </vbox>
                    </split>
                </tab>
                <tab id="emailSettingsTab" caption="msg://msgEmailSettings" margin="true" spacing="true" expand="emailScrollBox">
                    <scrollBox id="emailScrollBox" width="100%" height="100%" spacing="true">
                        <groupBox id="propertiesEmailBox" width="100%">
                            <grid id="propertiesEmailGrid" width="100%" spacing="true">
                                <columns>
                                    <column flex="1"/>
                                    <column flex="1"/>
                                    <column flex="0"/>
                                    <column flex="1"/>
                                    <column flex="1"/>
                                </columns>
                                <rows>
                                    <row>
                                        <fieldGroup id="emailFieldGroupLeft" datasource="userDs" width="AUTO">
                                            <column width="300px">
                                                <field id="smtpServer" caption="SMTP server"/>
                                                <field id="pop3Server" caption="POP3 server"/>
                                                <field id="imapServer" caption="IMAP server"/>
                                            </column>
                                        </fieldGroup>
                                        <fieldGroup id="emailFieldGroupRight" datasource="userDs" width="AUTO">
                                            <column width="300px">
                                                <field id="smtpPort" caption="SMTP port">
                                                    <validator class="com.haulmont.cuba.gui.components.validators.IntegerValidator"/>
                                                </field>
                                                <field id="pop3Port" caption="POP3 port">
                                                    <validator class="com.haulmont.cuba.gui.components.validators.IntegerValidator"/>
                                                </field>
                                                <field id="imapPort" caption="IMAP port">
                                                    <validator class="com.haulmont.cuba.gui.components.validators.IntegerValidator"/>
                                                </field>
                                            </column>
                                        </fieldGroup>
                                        <fieldGroup id="emailFieldPasswordRequired" datasource="userDs" width="AUTO">
                                            <column width="30px">
                                                <field id="smtpPasswordRequired"/>
                                                <field id="pop3PasswordRequired"/>
                                                <field id="imapPasswordRequired"/>
                                            </column>
                                        </fieldGroup>
                                        <fieldGroup id="emailFieldGroupUser" datasource="userDs" width="AUTO">
                                            <column width="300px">
                                                <field id="smtpUser" caption="SMTP user"/>
                                                <field id="pop3User" caption="POP3 user"/>
                                                <field id="imapUser" caption="IMAP user"/>
                                            </column>
                                        </fieldGroup>
                                        <fieldGroup id="emailFieldGroupPasswords" datasource="userDs" width="AUTO">
                                            <column width="300px">
                                                <field id="smtpPassword" caption="SMTP password"/>
                                                <field id="pop3Password" caption="POP3 password"/>
                                                <field id="imapPassword" caption="IMAP password"/>
                                            </column>
                                        </fieldGroup>
                                    </row>
                                </rows>
                            </grid>
                        </groupBox>
                    </scrollBox>
                </tab>
                <tab id="aiSettingsTab" caption="msg://msgAiSettings" margin="true" spacing="true" expand="aiConfigsTable">
                    <label value="msg://msgAiSettingsHint" stylename="light"/>
                    <buttonsPanel id="aiConfigsButtonsPanel">
                        <button id="aiConfigsCreateBtn" caption="msg://actions.Create" icon="CREATE_ACTION"/>
                        <button id="aiConfigsEditBtn" caption="msg://actions.Edit" icon="EDIT"/>
                        <button id="aiConfigsRemoveBtn" caption="msg://actions.Remove" icon="REMOVE"/>
                    </buttonsPanel>
                    <table id="aiConfigsTable" width="100%" height="100%" editable="false">
                        <columns>
                            <column id="providerCode"/>
                            <column id="defaultModelName"/>
                            <column id="isActive"/>
                        </columns>
                        <rows datasource="userAiConfigsDs"/>
                    </table>
                </tab>
            </tabSheet>
        </split>
        <hbox id="bottomActionsBox" width="100%" spacing="true" align="BOTTOM_RIGHT">
            <button id="changePasswordBtn" caption="msg://msgChangePassword" icon="KEY" stylename="friendly"/>
            <label value="" expand="true"/>
            <fragment id="windowActions" screen="editWindowActions"/>
        </hbox>
    </layout>
</window>
