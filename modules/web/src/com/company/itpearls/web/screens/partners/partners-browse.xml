<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<window xmlns="http://schemas.haulmont.com/cuba/screen/window.xsd"
        xmlns:c="http://schemas.haulmont.com/cuba/screen/jpql_condition.xsd"
        xmlns:ext="http://schemas.haulmont.com/cuba/window-ext.xsd"
        extends="com/company/itpearls/web/screens/company/company-browse.xml"
        messagesPack="com.company.itpearls.web.screens.partners">
    <data readOnly="true">
        <collection id="companiesDc"
                    class="com.company.itpearls.entity.Partners"
                    view="partners-view">
            <loader id="companiesDl" cacheable="true">
                <query>
                    <![CDATA[select e from itpearls_Partners e
                    where e.signPartner = true
                    order by e.comanyName]]>
                    <condition>
                        <and>
                            <c:jpql>
                                <c:where>e.ourClient = :setOurClient</c:where>
                            </c:jpql>
                            <c:jpql>
                                <c:where>e.ourLegalEntity = :setOurLegalEntity</c:where>
                            </c:jpql>
                        </and>
                    </condition>
                </query>
            </loader>
        </collection>
    </data>
    <layout>
        <treeDataGrid id="companiesTable">
            <columns>
                <column id="partners" collapsible="true" collapsed="true"/>
                <column id="ourCompanyIconColumn"
                        collapsed="true"
                        collapsible="true"/>
                <column id="ourClientIconColumn"
                        collapsed="true"
                        collapsible="true"/>
            </columns>
        </treeDataGrid>
    </layout>
</window>
