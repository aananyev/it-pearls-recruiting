<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<window xmlns="http://schemas.haulmont.com/cuba/screen/window.xsd"
        xmlns:ext="http://schemas.haulmont.com/cuba/window-ext.xsd"
        extends="com/company/itpearls/web/screens/person/person-browse.xml"
        messagesPack="com.company.itpearls.web.screens.partnersperson">
    <data readOnly="true">
        <collection id="personsDc"
                    class="com.company.itpearls.entity.PartnersPerson"
                    view="partnersPerson-view">
            <loader id="personsDl">
                <query>
                    <![CDATA[select e from itpearls_PartnersPerson e order by e.secondName, e.firstName]]>
                </query>
            </loader>
        </collection>
    </data>
    <layout>
        <dataGrid id="personsTable">
            <columns>
                <column id="partnerColumn" property="partners"
                        caption="msg://msgPartner"
                        ext:index="0"/>
            </columns>
        </dataGrid>
    </layout>
</window>
