<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<window xmlns="http://schemas.haulmont.com/cuba/screen/window.xsd"
        xmlns:ext="http://schemas.haulmont.com/cuba/window-ext.xsd"
        extends="com/company/itpearls/web/screens/person/person-edit.xml"
        messagesPack="com.company.itpearls.web.screens.partnersperson">
    <data>
        <instance id="personDc"
                  class="com.company.itpearls.entity.PartnersPerson"
                  view="partnersPerson-view">
            <loader/>
        </instance>
        <collection id="partnersDc" class="com.company.itpearls.entity.Partners" view="_local">
            <loader id="partnersDl">
                <query><![CDATA[select e from itpearls_Partners e]]></query>
            </loader>
        </collection>
    </data>
    <layout>
        <hbox id="mainHBox">
            <form id="form">
                <lookupPickerField id="partnersField" property="partner"
                                   caption="msg://msgPartner"
                                   optionsContainer="partnersDc">
                    <actions>
                        <action id="lookup" type="picker_lookup"/>
                    </actions>
                </lookupPickerField>
            </form>
        </hbox>
    </layout>
</window>
