<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<window xmlns="http://schemas.haulmont.com/cuba/screen/window.xsd"
        xmlns:c="http://schemas.haulmont.com/cuba/screen/jpql_condition.xsd"
        caption="msg://userAiConfigurationBrowse.caption"
        focusComponent="userAiConfigurationsTable"
        messagesPack="com.company.itpearls.web.screens.useraiconfiguration">
    <data readOnly="true">
        <collection id="userAiConfigurationsDc"
                    class="com.company.itpearls.entity.UserAiConfiguration">
            <view extends="userAiConfiguration-browse-view"/>
            <loader id="userAiConfigurationsDl">
                <query>
                    <![CDATA[select e from itpearls_UserAiConfiguration e]]>
                </query>
            </loader>
        </collection>
    </data>
    <dialogMode height="600"
                width="1000"/>
    <layout expand="userAiConfigurationsTable"
            spacing="true">
        <filter id="filter"
                applyTo="userAiConfigurationsTable"
                dataLoader="userAiConfigurationsDl">
            <properties include=".*"/>
        </filter>
        <groupTable id="userAiConfigurationsTable"
                    width="100%"
                    dataContainer="userAiConfigurationsDc">
            <columns>
                <column id="user.login"/>
                <column id="providerCode"/>
                <column id="isActive"/>
                <column id="defaultModelName"/>
            </columns>
            <rowsCount/>
        </groupTable>
        <hbox id="lookupActions" spacing="true" visible="false">
            <button action="lookupSelectAction"/>
            <button action="lookupCancelAction"/>
        </hbox>
    </layout>
</window>
